{
  "name": "verto",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-links": "node --env-file=.env scripts/fetch-tracking-links.mjs",
    "discover": "node --env-file=.env scripts/fetch-tracking-links.mjs --discover",
