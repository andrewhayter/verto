---
import { categories } from '../data/categories';
---

<footer class="bg-slate-900 text-white/60 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="font-display font-black text-2xl tracking-tight block mb-3">
          <span class="text-white">VER</span><span class="text-brand">TO</span>
        </a>
        <p class="text-sm leading-relaxed text-white/50">
          Your trusted guide to the internet's best offers, deals, and opportunities — reviewed by real humans.
        </p>
        <div class="flex gap-3 mt-5">
          <a href="#" aria-label="Twitter" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav + Categories grid -->
      <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-4 gap-8">
        <!-- Quick links -->
        <div class="sm:col-span-1">
          <h3 class="text-white text-sm font-semibold uppercase tracking-widest mb-4">Quick Links</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/solve" class="text-white/50 hover:text-white transition-colors">Solution Finder</a>
            <a href="/topics" class="text-white/50 hover:text-white transition-colors">Trending Topics</a>
            <a href="/categories" class="text-white/50 hover:text-white transition-colors">All Categories</a>
            <a href="/about" class="text-white/50 hover:text-white transition-colors">About & Disclosure</a>
          </nav>
        </div>
        <!-- Categories -->
        <div class="sm:col-span-3">
          <h3 class="text-white text-sm font-semibold uppercase tracking-widest mb-4">Browse Categories</h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
            {categories.map(cat => (
              <a
                href={`/category/${cat.slug}`}
                class="flex items-center gap-2 text-white/50 hover:text-white text-xs py-1 transition-colors group"
              >
                <span class="group-hover:scale-110 transition-transform text-sm">{cat.emoji}</span>
                <span class="truncate">{cat.name}</span>
                <span class="text-white/20 text-xs ml-auto shrink-0">({cat.offsCount})</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/30">
      <p>© {new Date().getFullYear()} Verto Media. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/about" class="hover:text-white/60 transition-colors">About</a>
        <a href="/about#disclosure" class="hover:text-white/60 transition-colors">Affiliate Disclosure</a>
        <a href="/privacy" class="hover:text-white/60 transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white/60 transition-colors">Terms</a>
      </div>
      <p class="text-center sm:text-right">
        Verto contains affiliate links. We may earn a commission at no cost to you.
      </p>
    </div>
  </div>
</footer>
