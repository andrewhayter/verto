---
import { categories } from '../data/categories';
import { problems } from '../data/problems';
import { offersByProblem } from '../data/offers';

const featuredGuides = problems
  .filter(p => (offersByProblem[p.slug] ?? []).filter(o => o.approved).length > 0)
  .slice(0, 6);
---

<footer class="bg-slate-900 text-white/60 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">

    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10 pb-12 border-b border-white/10">

      <!-- Brand col -->
      <div class="md:col-span-1">
        <a href="/" class="font-display font-black text-2xl tracking-tight block mb-3">
          <span class="text-white">VER</span><span class="text-brand">TO</span>
        </a>
        <p class="text-sm leading-relaxed text-white/50 mb-5">
          We cover the problems people are paying to solve — weight loss, loans, privacy, legal documents — and tell you which solution is actually worth the money.
        </p>
        <a
          href="/best"
          class="inline-flex items-center gap-2 bg-cta hover:bg-cta-dark text-white text-xs font-bold px-4 py-2.5 rounded-lg transition-colors"
        >
          Start Here →
        </a>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Navigate</h3>
        <nav class="flex flex-col gap-2 text-sm">
          <a href="/best"        class="text-white/50 hover:text-white transition-colors">Guides</a>
          <a href="/reviews"     class="text-white/50 hover:text-white transition-colors">All Reviews</a>
          <a href="/explore"     class="text-white/50 hover:text-white transition-colors">Explore Topics</a>
          <a href="/calculators" class="text-white/50 hover:text-white transition-colors">Free Calculators</a>
          <a href="/about"       class="text-white/50 hover:text-white transition-colors">About & Disclosure</a>
        </nav>
      </div>

      <!-- Top problem guides -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Top Guides</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-1">
          {featuredGuides.map(p => (
            <a
              href={`/best/${p.slug}`}
              class="flex items-center gap-2 text-white/50 hover:text-white text-sm py-1.5 transition-colors group"
            >
              <span class="text-base shrink-0">{p.emoji}</span>
              <span class="group-hover:underline line-clamp-1 text-xs leading-snug">
                {p.headline.split('—')[0].split(':')[0].trim().substring(0, 40)}
              </span>
            </a>
          ))}
        </div>
        <a href="/best" class="inline-block mt-3 text-xs font-semibold text-brand hover:text-red-400 transition-colors">
          All {problems.length} guides →
        </a>
      </div>

      <!-- Topics -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Browse by Topic</h3>
        <div class="flex flex-col gap-1">
          {categories.slice(0, 12).map(cat => (
            <a
              href={`/${cat.slug}/`}
              class="flex items-center gap-1.5 text-white/50 hover:text-white text-xs py-1 transition-colors group"
            >
              <span>{cat.emoji}</span>
              <span class="group-hover:underline truncate max-w-[140px]">{cat.name}</span>
            </a>
          ))}
          <a href="/explore" class="text-brand hover:text-red-400 text-xs mt-1 transition-colors">
            Explore all topics →
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/30">
      <p>© {new Date().getFullYear()} Verto. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/about"              class="hover:text-white/60 transition-colors">About</a>
        <a href="/about#disclosure"   class="hover:text-white/60 transition-colors">Affiliate Disclosure</a>
        <a href="/privacy"            class="hover:text-white/60 transition-colors">Privacy Policy</a>
        <a href="/terms"              class="hover:text-white/60 transition-colors">Terms</a>
      </div>
      <p class="text-center sm:text-right max-w-xs">
        Verto contains affiliate links. We may earn a commission at no cost to you.
      </p>
    </div>
  </div>
</footer>
