---
import { categoryBySlug } from '../data/categories';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  slug: string;
  author: string;
  date: Date;
  readTime: number;
  sponsored?: boolean;
  variant?: 'default' | 'compact' | 'horizontal';
  image?: string;
}

const {
  title,
  description,
  category,
  slug,
  author,
  date,
  readTime,
  sponsored = true,
  variant = 'default',
  image,
} = Astro.props;

const cat = categoryBySlug[category];
const gradient = cat?.gradient ?? 'linear-gradient(135deg, #475569, #1e293b)';
const formattedDate = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(date);
const href = `/${category}/${slug}`;
const imgSrc = image ?? `/images/${category}.jpg`;
---

{variant === 'horizontal' ? (
  <a href={href} class="article-card group flex gap-4 bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:border-gray-200">
    <div class="w-32 shrink-0 h-28 overflow-hidden">
      <img src={imgSrc} alt={title} class="w-full h-full object-cover" onerror={`this.src='/images/default.jpg'`} />
    </div>
    <div class="flex flex-col justify-center py-3 pr-4 gap-1.5">
      <CategoryBadge slug={category} size="sm" />
      <h3 class="font-display font-bold text-sm text-gray-900 leading-snug group-hover:text-brand line-clamp-2 transition-colors">{title}</h3>
      <p class="text-xs text-gray-500">{formattedDate} · {readTime} min read</p>
    </div>
  </a>
) : variant === 'compact' ? (
  <a href={href} class="article-card group flex gap-3 items-start py-3 border-b border-gray-100 last:border-0">
    <div class="w-16 h-14 rounded-lg shrink-0 overflow-hidden">
      <img src={imgSrc} alt={title} class="w-full h-full object-cover" onerror={`this.src='/images/default.jpg'`} />
    </div>
    <div class="flex flex-col gap-1">
      <CategoryBadge slug={category} size="sm" />
      <h3 class="font-display font-semibold text-sm text-gray-900 leading-tight group-hover:text-brand line-clamp-2 transition-colors">{title}</h3>
      <p class="text-xs text-gray-400">{readTime} min read</p>
    </div>
  </a>
) : (
  <a href={href} class="article-card group flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:border-gray-200">
    <div class="relative h-44 w-full overflow-hidden">
      <img src={imgSrc} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" onerror={`this.src='/images/default.jpg'`} />
      <div class="absolute bottom-3 left-3">
        <CategoryBadge slug={category} size="sm" />
      </div>
    </div>
    <div class="flex flex-col gap-2 p-5">
      <h3 class="font-display font-bold text-lg text-gray-900 leading-snug group-hover:text-brand transition-colors line-clamp-3">{title}</h3>
      <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{description}</p>
      <div class="flex items-center gap-2 pt-1 text-xs text-gray-400">
        <span>{author}</span>
        <span>·</span>
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{readTime} min</span>
      </div>
    </div>
  </a>
)}
