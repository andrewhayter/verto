---
import { categoryBySlug } from '../data/categories';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  slug: string;
  author: string;
  date: Date;
  readTime: number;
  ctaText?: string;
}

const { title, description, category, slug, author, date, readTime, ctaText } = Astro.props;
const cat = categoryBySlug[category];
const gradient = cat?.gradient ?? 'linear-gradient(135deg, #0f172a, #1e1b4b)';
const formattedDate = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(date);
---

<a
  href={`/${category}/${slug}`}
  class="hero-card group relative flex items-end rounded-3xl overflow-hidden min-h-[500px] md:min-h-[560px] w-full"
  style={`background: ${gradient}`}
>
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

  <div class="relative z-10 p-8 md:p-12 flex flex-col gap-4 max-w-3xl">
    <div class="flex items-center gap-3">
      <span class="bg-brand text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
        Featured
      </span>
      <CategoryBadge slug={category} size="sm" />
    </div>

    <h1 class="font-display text-3xl md:text-5xl font-bold text-white leading-tight group-hover:text-white/90 transition-colors">
      {title}
    </h1>

    <p class="text-white/80 text-base md:text-lg leading-relaxed line-clamp-3 max-w-2xl">
      {description}
    </p>

    <div class="flex items-center gap-4 text-white/60 text-sm">
      <span>By {author}</span>
      <span>·</span>
      <span>{formattedDate}</span>
      <span>·</span>
      <span>{readTime} min read</span>
    </div>

    {ctaText && (
      <div class="mt-2">
        <span class="inline-flex items-center gap-2 bg-white text-gray-900 font-semibold px-6 py-3 rounded-xl text-sm group-hover:bg-gray-100 transition-colors">
          {ctaText}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    )}
  </div>
</a>
