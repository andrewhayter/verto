---
import type { Offer } from '../data/offers';
import { getAffiliateUrl } from '../data/offers';

interface Props {
  offer: Offer;
  rank?: number;
  problemSlug?: string;
  variant?: 'full' | 'compact' | 'featured';
}

const { offer, rank, problemSlug, variant = 'full' } = Astro.props;
const affiliateUrl = getAffiliateUrl(offer, problemSlug);
const geoLabel = offer.geos.includes('WW') ? 'Worldwide' : offer.geos.join(', ');
---

{variant === 'featured' && (
  <div class="relative rounded-3xl overflow-hidden border-2 border-brand shadow-lg bg-white">
    <div class="absolute top-4 right-4 bg-brand text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
      Editor's Pick
    </div>
    <div class="p-6 md:p-8">
      <div class="flex items-start gap-4 mb-5">
        {rank && (
          <span class="text-5xl font-display font-black text-gray-100 leading-none mt-1 shrink-0">{rank}</span>
        )}
        <div class="flex-1">
          {offer.badge && (
            <span class="inline-block bg-brand/10 text-brand text-xs font-bold uppercase tracking-widest px-2.5 py-1 rounded-full mb-2">
              {offer.badge}
            </span>
          )}
          <h3 class="font-display font-bold text-xl text-gray-900 mb-1">{offer.shortName}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{offer.tagline}</p>
        </div>
      </div>

      {offer.trustSignal && (
        <div class="flex items-center gap-2 bg-gray-50 rounded-xl px-4 py-2.5 mb-5">
          <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-sm text-gray-700 font-medium">{offer.trustSignal}</span>
        </div>
      )}

      <div class="flex items-center justify-between gap-4 mb-5">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-0.5">Available in</p>
          <p class="text-sm font-semibold text-gray-700">{geoLabel}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-0.5">Payout</p>
          <p class="text-sm font-semibold text-gray-700">{offer.payout}</p>
        </div>
      </div>

      <a
        href={affiliateUrl}
        rel="sponsored noopener"
        target="_blank"
        class="block w-full text-center bg-brand hover:bg-brand-dark text-white font-bold text-base px-6 py-4 rounded-2xl transition-colors"
      >
        {offer.ctaText}
        <svg class="inline-block w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      {offer.ctaSubtext && (
        <p class="text-center text-xs text-gray-400 mt-2">{offer.ctaSubtext}</p>
      )}
    </div>
  </div>
)}

{variant === 'full' && (
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
    <div class="p-5">
      <div class="flex items-start gap-3 mb-4">
        {rank && (
          <span class="text-3xl font-display font-black text-gray-100 leading-none mt-1 shrink-0 w-8">{rank}</span>
        )}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <h3 class="font-display font-bold text-gray-900">{offer.shortName}</h3>
            {offer.badge && (
              <span class="bg-brand/10 text-brand text-xs font-bold px-2 py-0.5 rounded-full whitespace-nowrap">
                {offer.badge}
              </span>
            )}
            {offer.approved && (
              <span class="bg-green-50 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full whitespace-nowrap">
                ✓ Approved
              </span>
            )}
          </div>
          <p class="text-sm text-gray-500 leading-snug">{offer.tagline}</p>
        </div>
      </div>

      {offer.trustSignal && (
        <p class="text-sm text-gray-600 bg-gray-50 rounded-lg px-3 py-2 mb-4">
          ✓ {offer.trustSignal}
        </p>
      )}

      <div class="flex items-center justify-between gap-3 mb-4">
        <div class="text-xs text-gray-400">
          <span class="font-semibold text-gray-600">{geoLabel}</span>
        </div>
        <div class="text-xs text-gray-400 text-right">
          <span class="font-semibold text-gray-600">{offer.payout}</span>
        </div>
      </div>

      <a
        href={affiliateUrl}
        rel="sponsored noopener"
        target="_blank"
        class="block w-full text-center bg-brand hover:bg-brand-dark text-white font-semibold text-sm px-4 py-3 rounded-xl transition-colors"
      >
        {offer.ctaText}
        <svg class="inline-block w-3.5 h-3.5 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      {offer.ctaSubtext && (
        <p class="text-center text-xs text-gray-400 mt-1.5">{offer.ctaSubtext}</p>
      )}
    </div>
  </div>
)}

{variant === 'compact' && (
  <div class="flex items-center gap-4 bg-white rounded-xl border border-gray-100 p-4 hover:border-brand/30 transition-colors">
    {rank && (
      <span class="text-xl font-display font-black text-gray-200 shrink-0 w-6 text-center">{rank}</span>
    )}
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-0.5">
        <span class="font-semibold text-sm text-gray-900 truncate">{offer.shortName}</span>
        {offer.badge && (
          <span class="bg-brand/10 text-brand text-xs font-bold px-1.5 py-0.5 rounded-full shrink-0">
            {offer.badge}
          </span>
        )}
      </div>
      <p class="text-xs text-gray-500 truncate">{offer.tagline}</p>
    </div>
    <a
      href={affiliateUrl}
      rel="sponsored noopener"
      target="_blank"
      class="shrink-0 bg-brand hover:bg-brand-dark text-white text-xs font-bold px-3 py-2 rounded-lg transition-colors whitespace-nowrap"
    >
      {offer.ctaText}
    </a>
  </div>
)}
