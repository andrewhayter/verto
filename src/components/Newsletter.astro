---
---
<section class="bg-gradient-to-br from-slate-900 to-indigo-950 rounded-3xl p-8 md:p-12 text-center">
  <div class="max-w-xl mx-auto flex flex-col gap-4">
    <div class="inline-flex items-center justify-center w-12 h-12 bg-brand/20 rounded-2xl mx-auto">
      <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <h2 class="font-display text-2xl md:text-3xl font-bold text-white">
      Get the Best Deals in Your Inbox
    </h2>
    <p class="text-white/70 text-base">
      Top offers, expert reviews, and money-saving tips — curated daily by the Verto editorial team.
    </p>
    <form class="flex flex-col sm:flex-row gap-3 mt-2" onsubmit="return false;">
      <input
        type="email"
        placeholder="Enter your email"
        class="flex-1 px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/60 text-sm"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-brand hover:bg-brand-dark text-white font-semibold rounded-xl text-sm transition-colors whitespace-nowrap"
      >
        Subscribe Free
      </button>
    </form>
    <p class="text-white/40 text-xs">No spam. Unsubscribe anytime. 47,000+ subscribers.</p>
  </div>
</section>
