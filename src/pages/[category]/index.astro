---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import { categories, categoryBySlug } from '../../data/categories';
import { problems } from '../../data/problems';
import { offersByProblem, getAffiliateUrl } from '../../data/offers';
import { topicsByCategory } from '../../data/topics';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
  }));
}

const slug = Astro.params.category;
const category = categoryBySlug[slug];

if (!category) return Astro.redirect('/');

const allArticles = await getCollection('articles');
const categoryArticles = allArticles
  .filter(a => a.data.category === slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getArticleSlug(article: (typeof allArticles)[0]) {
  const parts = article.id.split('/');
  return parts[parts.length - 1].replace(/\.mdx?$/, '');
}

const catTopics = (topicsByCategory[slug] ?? []).slice(0, 32);

const otherCategories = categories
  .filter(c => c.slug !== slug)
  .sort((a, b) => b.offsCount - a.offsCount)
  .slice(0, 10);

// Problem guides for this category
const categoryProblems = problems
  .filter(p => p.category === slug && (offersByProblem[p.slug] ?? []).filter(o => o.approved).length > 0)
  .slice(0, 3);
---

<BaseLayout
  title={`${category.name} — ${category.offsCount} Verified Offers Compared | Verto`}
  description={`Browse ${category.offsCount} vetted ${category.name.toLowerCase()} offers. ${category.description}`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "name": `${category.name} — ${category.offsCount} Verified Offers`,
        "description": category.description,
        "url": Astro.url.href,
        "publisher": { "@type": "Organization", "name": "Verto", "url": "https://verto.fun" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://verto.fun" },
          { "@type": "ListItem", "position": 2, "name": category.name, "item": Astro.url.href }
        ]
      }
    ]
  })} />

  <!-- Category hero -->
  <div class="relative py-14 md:py-20" style={`background: ${category.gradient}`}>
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-4xl">{category.emoji}</span>
          <span class="text-white/60 text-sm font-medium uppercase tracking-widest">
            {category.offsCount} offers available
          </span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3">
          {category.name}
        </h1>
        <p class="text-white/80 text-lg">{category.description}</p>
      </div>
    </div>
  </div>

  <!-- Problem guides for this category — funnel entry before article browsing -->
  {categoryProblems.length > 0 && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 border-b border-gray-100">
      <div class="flex items-center justify-between mb-5">
        <div>
          <p class="eyebrow text-brand mb-1">Solve Your Problem</p>
          <h2 class="font-display font-bold text-xl text-gray-900">
            {categoryProblems.length === 1 ? 'Top Solution Guide' : `${categoryProblems.length} Solution Guides`} in {category.name}
          </h2>
        </div>
        <a href="/best" class="text-sm font-semibold text-brand hover:text-brand-dark transition-colors whitespace-nowrap">
          All guides →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categoryProblems.map(problem => {
          const topOffer = (offersByProblem[problem.slug] ?? []).filter(o => o.approved)[0];
          return (
            <a
              href={`/best/${problem.slug}`}
              class="group relative flex flex-col justify-between rounded-2xl overflow-hidden p-5 min-h-[160px] hover:shadow-lg transition-all"
              style={`background: ${problem.gradient}`}
            >
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/30 transition-colors"></div>
              <div class="relative z-10">
                <div class="text-2xl mb-2">{problem.emoji}</div>
                <h3 class="font-display font-bold text-white text-base leading-snug line-clamp-2">
                  {problem.headline.split('—')[0].trim().substring(0, 60)}
                </h3>
              </div>
              <div class="relative z-10 mt-3">
                {topOffer && (
                  <p class="text-white/60 text-xs mb-1.5">
                    Top pick: <span class="text-white font-semibold">{topOffer.shortName}</span>
                  </p>
                )}
                <span class="inline-flex items-center gap-1.5 text-xs font-bold bg-white/15 hover:bg-white/25 text-white px-3 py-1.5 rounded-full transition-colors">
                  See Options →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  )}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <!-- Main content -->
      <div class="lg:col-span-3">
        {categoryArticles.length > 0 ? (
          <>
            {(() => {
              const featured = categoryArticles[0];
              return (
                <a
                  href={`/${featured.data.category}/${getArticleSlug(featured)}`}
                  class="article-card group relative flex items-end rounded-3xl overflow-hidden h-72 mb-8 block"
                  style={`background: ${category.gradient}`}
                >
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                  <div class="relative z-10 p-8 flex flex-col gap-2">
                    <span class="inline-block bg-brand text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full w-fit mb-1">
                      Latest
                    </span>
                    <h2 class="font-display font-bold text-2xl md:text-3xl text-white group-hover:text-white/90 transition-colors line-clamp-2">
                      {featured.data.title}
                    </h2>
                    <p class="text-white/70 line-clamp-1">{featured.data.description}</p>
                    <p class="text-white/50 text-sm">
                      By {featured.data.author} · {featured.data.readTime} min read
                    </p>
                  </div>
                </a>
              );
            })()}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {categoryArticles.slice(1).map(article => (
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  category={article.data.category}
                  slug={getArticleSlug(article)}
                  author={article.data.author}
                  date={article.data.date}
                  readTime={article.data.readTime}
                  sponsored={article.data.sponsored}
                />
              ))}
            </div>
          </>
        ) : (
          <div class="text-center py-24 rounded-3xl border-2 border-dashed border-gray-200">
            <p class="text-5xl mb-4">{category.emoji}</p>
            <h2 class="font-display font-bold text-2xl text-gray-700 mb-2">Coming Soon</h2>
            <p class="text-gray-400">We're working on expert reviews and guides for {category.name}.</p>
          </div>
        )}

        {catTopics.length > 0 && (
          <div class="mt-10">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-display font-bold text-xl text-gray-900">
                Trending Topics in {category.name}
              </h2>
              <a href="/topics" class="text-brand text-sm font-semibold hover:text-brand-dark transition-colors">
                All Topics →
              </a>
            </div>
            <div class="flex flex-wrap gap-2">
              {catTopics.map(t => (
                <a
                  href={`/topic/${t.slug}`}
                  class="px-3.5 py-2 bg-white border border-gray-200 hover:border-brand hover:text-brand text-gray-600 text-sm font-medium rounded-xl transition-colors"
                >
                  {t.name}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="mt-12">
          <Newsletter />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1 flex flex-col gap-6">
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <div class="h-24 flex items-center justify-center text-4xl" style={`background: ${category.gradient}`}>
            {category.emoji}
          </div>
          <div class="p-5">
            <h3 class="font-display font-bold text-gray-900 mb-1">{category.name}</h3>
            <p class="text-sm text-gray-500 mb-3">{category.description}</p>
            <div class="flex items-center gap-2 text-sm">
              <span class="font-bold text-gray-900">{category.offsCount}</span>
              <span class="text-gray-400">active offers</span>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h3 class="font-display font-bold text-gray-900 text-base mb-4">Other Categories</h3>
          <div class="flex flex-col gap-2">
            {otherCategories.map(cat => (
              <a
                href={`/${cat.slug}/`}
                class="flex items-center justify-between text-gray-600 hover:text-brand text-sm py-1.5 border-b border-gray-50 last:border-0 transition-colors group"
              >
                <span class="flex items-center gap-2">
                  <span>{cat.emoji}</span>
                  <span class="group-hover:underline">{cat.name}</span>
                </span>
                <span class="text-gray-300 text-xs">{cat.offsCount}</span>
              </a>
            ))}
          </div>
          <a
            href="/categories"
            class="block text-center text-brand text-sm font-semibold mt-4 hover:text-brand-dark transition-colors"
          >
            View All Categories →
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
