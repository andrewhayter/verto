---
import BaseLayout from '../../layouts/BaseLayout.astro';

const compensairUrl = "https://afflat3e3.com/trk/lnk/8A3315A3-62A1-4C51-A6AA-8C3C27C5B9BB/?o=16819&c=918277&a=784951&k=0&l=29712";
---

<BaseLayout
  title="EU Flight Delay Compensation Calculator — What the Airline Owes You"
  description="EU regulation EC 261/2004 entitles passengers to €250–€600 when flights are delayed 3+ hours or cancelled. Enter your route to see exactly what compensation you're owed — and how to claim it."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "EU Flight Delay Compensation Calculator",
    "description": "Calculate your EC 261/2004 flight delay compensation entitlement for delays, cancellations, and denied boarding on EU and UK flights.",
    "url": "https://verto.pages.dev/calculators/flight-delay",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    }
  })} />

  <div class="max-w-3xl mx-auto px-4 py-10">

    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-widest text-[#dc2626] mb-3">Flight Delay Calculator</div>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
        Your Flight Was Delayed. The Airline May Legally Owe You Up to €600.
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        EU Regulation EC 261/2004 mandates compensation of €250–€600 per passenger for delays over 3 hours, cancellations, and denied boarding on qualifying routes. Airlines pay fewer than 2% of eligible claims voluntarily. This calculator shows what you're owed — and how to claim it.
      </p>
    </div>

    <!-- Quick explainer bar -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-8 flex gap-3">
      <span class="text-yellow-600 text-lg shrink-0">⚠</span>
      <div class="text-sm text-yellow-900">
        <strong>3-year claim window:</strong> EU 261 claims can be filed up to 3 years after the disrupted flight. You may be eligible for flights that happened in 2023 or 2024.
      </div>
    </div>

    <!-- Calculator -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 md:p-8 mb-8">
      <h2 class="font-display text-xl font-bold text-gray-900 mb-6">Check Your Eligibility</h2>

      <div class="space-y-6">

        <!-- Route type -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">Which best describes your flight?</label>
          <div class="space-y-3">
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="radio" name="route" value="eu-eu" class="mt-1 accent-[#dc2626]" checked />
              <div>
                <div class="font-medium text-gray-900">Both departure and arrival in the EU/UK</div>
                <div class="text-sm text-gray-500">e.g. London → Paris, Amsterdam → Rome</div>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="radio" name="route" value="eu-out" class="mt-1 accent-[#dc2626]" />
              <div>
                <div class="font-medium text-gray-900">Departed from EU/UK, arrived outside EU/UK</div>
                <div class="text-sm text-gray-500">e.g. Paris → New York, London → Dubai</div>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="radio" name="route" value="out-eu-eu" class="mt-1 accent-[#dc2626]" />
              <div>
                <div class="font-medium text-gray-900">Departed outside EU, arrived in EU/UK on an EU carrier</div>
                <div class="text-sm text-gray-500">e.g. New York → Paris on Air France; New York → London on British Airways</div>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="radio" name="route" value="out-eu-noneu" class="mt-1 accent-[#dc2626]" />
              <div>
                <div class="font-medium text-gray-900">Departed outside EU on a non-EU carrier, arrived in EU/UK</div>
                <div class="text-sm text-gray-500">e.g. New York → London on Delta or United</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Disruption type -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">What happened?</label>
          <div class="grid md:grid-cols-3 gap-3">
            <label class="cursor-pointer">
              <input type="radio" name="disruption" value="delay" class="peer sr-only" checked />
              <div class="border-2 border-gray-200 rounded-lg p-4 peer-checked:border-[#dc2626] peer-checked:bg-[#fef2f2] transition-all">
                <div class="font-semibold text-sm text-gray-900">Flight delayed</div>
                <div class="text-xs text-gray-500 mt-1">Landed late at destination</div>
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="disruption" value="cancelled" class="peer sr-only" />
              <div class="border-2 border-gray-200 rounded-lg p-4 peer-checked:border-[#dc2626] peer-checked:bg-[#fef2f2] transition-all">
                <div class="font-semibold text-sm text-gray-900">Flight cancelled</div>
                <div class="text-xs text-gray-500 mt-1">Flight did not operate</div>
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="disruption" value="denied" class="peer sr-only" />
              <div class="border-2 border-gray-200 rounded-lg p-4 peer-checked:border-[#dc2626] peer-checked:bg-[#fef2f2] transition-all">
                <div class="font-semibold text-sm text-gray-900">Denied boarding</div>
                <div class="text-xs text-gray-500 mt-1">Bumped due to overbooking</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Delay hours (show only for delay) -->
        <div id="delay-hours-section">
          <label class="block text-sm font-semibold text-gray-700 mb-2">How many hours late did you arrive at your final destination?</label>
          <select id="delay-hours" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-gray-800 bg-white focus:outline-none focus:ring-2 focus:ring-[#dc2626]">
            <option value="1">Less than 2 hours late</option>
            <option value="2">2–3 hours late</option>
            <option value="3" selected>3–4 hours late</option>
            <option value="4">More than 4 hours late</option>
          </select>
        </div>

        <!-- Flight distance -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">Flight distance</label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="radio" name="distance" value="short" class="accent-[#dc2626]" />
              <span class="text-sm text-gray-800">Under 1,500 km <span class="text-gray-500">(e.g. London–Paris, Amsterdam–Berlin)</span></span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="radio" name="distance" value="medium" class="accent-[#dc2626]" checked />
              <span class="text-sm text-gray-800">1,500–3,500 km within EU, or 1,500–3,500 km intra-EU <span class="text-gray-500">(e.g. London–Canaries, Paris–Cairo)</span></span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="radio" name="distance" value="long" class="accent-[#dc2626]" />
              <span class="text-sm text-gray-800">Over 3,500 km <span class="text-gray-500">(e.g. London–New York, Paris–Singapore)</span></span>
            </label>
          </div>
        </div>

        <!-- Passengers -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Number of passengers claiming <span class="font-normal text-gray-500">(each gets the same amount)</span></label>
          <div class="flex items-center gap-4">
            <button id="pax-minus" class="w-10 h-10 rounded-full border-2 border-gray-300 font-bold text-lg text-gray-600 hover:border-[#dc2626] hover:text-[#dc2626] transition-colors">−</button>
            <span id="pax-count" class="text-2xl font-bold text-gray-900 w-8 text-center">1</span>
            <button id="pax-plus" class="w-10 h-10 rounded-full border-2 border-gray-300 font-bold text-lg text-gray-600 hover:border-[#dc2626] hover:text-[#dc2626] transition-colors">+</button>
          </div>
        </div>

        <button
          id="check-btn"
          class="w-full bg-[#dc2626] hover:bg-[#991b1b] text-white font-bold py-4 rounded-xl text-lg transition-colors"
        >
          Check My Compensation →
        </button>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="hidden">

      <div id="eligible-result" class="hidden">
        <div class="bg-green-50 border-2 border-green-400 rounded-2xl p-6 md:p-8 mb-6 text-center">
          <div class="text-sm font-semibold uppercase tracking-wider text-green-700 mb-2">You appear eligible for compensation</div>
          <div id="compensation-amount" class="text-5xl font-bold text-green-700 mb-2">€—</div>
          <div id="compensation-breakdown" class="text-sm text-green-700">—</div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 md:p-8 mb-6">
          <h3 class="font-display text-lg font-bold text-gray-900 mb-4">The fastest way to claim it</h3>
          <p class="text-gray-700 mb-3">Airlines pay fewer than 2% of eligible claims when contacted directly. Compensair is a claims service that handles the entire process — including legal escalation if the airline refuses. They charge a commission <em>only if the claim succeeds</em>. No upfront cost.</p>
          <ul class="text-sm text-gray-700 space-y-2 mb-5">
            <li class="flex gap-2"><span class="text-green-600 font-bold">✓</span> No-win, no-fee: Compensair takes a % only on successful claims</li>
            <li class="flex gap-2"><span class="text-green-600 font-bold">✓</span> Handles EU 261, UK261, and international claims</li>
            <li class="flex gap-2"><span class="text-green-600 font-bold">✓</span> Covers flights up to 3 years old</li>
            <li class="flex gap-2"><span class="text-green-600 font-bold">✓</span> Works on any device, takes 3 minutes to submit</li>
          </ul>
          <a
            href={compensairUrl}
            target="_blank"
            rel="noopener sponsored"
            class="block w-full text-center bg-[#dc2626] hover:bg-[#991b1b] text-white font-bold py-4 rounded-xl text-lg transition-colors"
          >
            File Your Claim — Compensair →
          </a>
          <p class="text-xs text-gray-500 text-center mt-3">Takes 3 minutes. No upfront cost. Commission only on success.</p>
        </div>
      </div>

      <div id="ineligible-result" class="hidden">
        <div class="bg-gray-50 border-2 border-gray-300 rounded-2xl p-6 md:p-8 mb-6">
          <div class="text-lg font-bold text-gray-900 mb-3" id="ineligible-heading">Your flight may not qualify under EC 261/2004</div>
          <p id="ineligible-reason" class="text-gray-700 mb-4">—</p>
          <p class="text-sm text-gray-600">You can still submit a claim through Compensair — their team will verify full eligibility including connecting flight rules, extraordinary circumstances exceptions, and jurisdiction. If you're not eligible, you won't be charged.</p>
          <a
            href={compensairUrl}
            target="_blank"
            rel="noopener sponsored"
            class="mt-4 inline-block text-[#dc2626] font-semibold hover:underline text-sm"
          >
            Check with Compensair anyway (free, no-win no-fee) →
          </a>
        </div>
      </div>

      <!-- EC 261 explainer -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 mb-6">
        <h3 class="font-display text-lg font-bold text-gray-900 mb-4">How EC 261/2004 Compensation Works</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 pr-4 font-semibold text-gray-700">Flight Distance</th>
                <th class="text-left py-2 pr-4 font-semibold text-gray-700">Delay 3+ hrs</th>
                <th class="text-left py-2 font-semibold text-gray-700">Cancellation</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr>
                <td class="py-3 pr-4 text-gray-700">Under 1,500 km</td>
                <td class="py-3 pr-4 font-semibold text-green-700">€250</td>
                <td class="py-3 font-semibold text-green-700">€250</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 text-gray-700">1,500–3,500 km (intra-EU)</td>
                <td class="py-3 pr-4 font-semibold text-green-700">€400</td>
                <td class="py-3 font-semibold text-green-700">€400</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 text-gray-700">Over 3,500 km</td>
                <td class="py-3 pr-4 font-semibold text-green-700">€600 (4+ hr delay)</td>
                <td class="py-3 font-semibold text-green-700">€600</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-4">Amounts may be reduced by 50% if the airline provides re-routing arriving within 2–4 hours of original schedule depending on distance. "Extraordinary circumstances" (genuine severe weather, air traffic control strikes, security incidents) may exempt the airline — technical faults and staff shortages do not qualify as extraordinary.</p>
      </div>

    </div>

  </div>

</BaseLayout>

<script define:vars={{ compensairUrl }}>
  let pax = 1;

  document.getElementById('pax-minus').addEventListener('click', () => {
    if (pax > 1) { pax--; document.getElementById('pax-count').textContent = pax; }
  });
  document.getElementById('pax-plus').addEventListener('click', () => {
    if (pax < 9) { pax++; document.getElementById('pax-count').textContent = pax; }
  });

  document.querySelectorAll('input[name="disruption"]').forEach(r => {
    r.addEventListener('change', () => {
      const val = r.value;
      document.getElementById('delay-hours-section').style.display =
        val === 'delay' ? 'block' : 'none';
    });
  });

  document.getElementById('check-btn').addEventListener('click', () => {
    const route = document.querySelector('input[name="route"]:checked')?.value;
    const disruption = document.querySelector('input[name="disruption"]:checked')?.value;
    const delayHours = parseInt(document.getElementById('delay-hours').value);
    const distance = document.querySelector('input[name="distance"]:checked')?.value;

    const results = document.getElementById('results');
    const eligibleResult = document.getElementById('eligible-result');
    const ineligibleResult = document.getElementById('ineligible-result');

    // Determine eligibility
    let eligible = true;
    let ineligibleReason = '';

    if (route === 'out-eu-noneu') {
      eligible = false;
      ineligibleReason = 'Flights arriving in the EU operated by a non-EU carrier from outside the EU are generally not covered by EC 261/2004. Compensation rights may exist under the carrier\'s national regulations or contract of carriage — Compensair can check.';
    } else if (disruption === 'delay' && delayHours < 3) {
      eligible = false;
      ineligibleReason = 'EC 261/2004 compensation applies when you arrived at your final destination 3 or more hours later than the scheduled time. Delays under 3 hours do not qualify for financial compensation under this regulation, though the airline may be required to provide meals and communications.';
    }

    // Calculate amount
    let baseAmount = 0;
    if (eligible) {
      if (distance === 'short') baseAmount = 250;
      else if (distance === 'medium') baseAmount = 400;
      else if (distance === 'long') {
        baseAmount = (disruption === 'delay' && delayHours === 3) ? 300 : 600;
      }
    }

    const totalAmount = baseAmount * pax;

    eligibleResult.classList.add('hidden');
    ineligibleResult.classList.add('hidden');

    if (eligible && baseAmount > 0) {
      document.getElementById('compensation-amount').textContent = '€' + totalAmount.toLocaleString();
      document.getElementById('compensation-breakdown').textContent =
        '€' + baseAmount + ' × ' + pax + ' passenger' + (pax > 1 ? 's' : '') + ' = €' + totalAmount.toLocaleString();
      eligibleResult.classList.remove('hidden');
    } else if (!eligible) {
      document.getElementById('ineligible-reason').textContent = ineligibleReason;
      ineligibleResult.classList.remove('hidden');
    }

    results.classList.remove('hidden');
    results.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
