---
import BaseLayout from '../layouts/BaseLayout.astro';
import { topics } from '../data/topics';
import { categories, categoryBySlug } from '../data/categories';

// Group by category
const grouped = topics.reduce((acc, t) => {
  if (!acc[t.category]) acc[t.category] = [];
  acc[t.category].push(t);
  return acc;
}, {} as Record<string, typeof topics>);

const sortedCategories = categories
  .filter(c => grouped[c.slug]?.length > 0)
  .sort((a, b) => (grouped[b.slug]?.length ?? 0) - (grouped[a.slug]?.length ?? 0));

// Most frequent topics (appeared in multiple keyword snapshots)
const trending = [...topics].sort((a, b) => b.frequency - a.frequency).slice(0, 30);
---

<BaseLayout
  title="Browse All Topics — Verto"
  description={`Explore ${topics.length} trending topics across ${categories.length} affiliate offer categories on Verto.`}
>
  <!-- Hero -->
  <div class="bg-slate-900 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3">
        All Topics
      </h1>
      <p class="text-white/60 text-lg max-w-xl">
        {topics.length.toLocaleString()} trending topics organized across {categories.length} categories.
        Each topic maps to curated offers, guides, and reviews.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">

    <!-- Trending topics -->
    <section class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-7 bg-brand rounded-full"></div>
        <h2 class="font-display font-bold text-2xl text-gray-900">🔥 Trending Topics</h2>
        <span class="text-gray-400 text-sm">Most searched across all categories</span>
      </div>
      <div class="flex flex-wrap gap-3">
        {trending.map(t => {
          const cat = categoryBySlug[t.category];
          return (
            <a
              href={`/topic/${t.slug}`}
              class="group inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 hover:border-brand hover:shadow-sm rounded-xl text-sm font-medium text-gray-700 hover:text-brand transition-all"
            >
              <span>{cat?.emoji ?? '📌'}</span>
              <span>{t.name}</span>
              {t.frequency > 5 && (
                <span class="bg-red-100 text-red-600 text-xs font-bold px-1.5 py-0.5 rounded-full">{t.frequency}×</span>
              )}
            </a>
          );
        })}
      </div>
    </section>

    <!-- By category -->
    {sortedCategories.map(cat => {
      const catTopics = grouped[cat.slug] ?? [];
      const shown = catTopics.slice(0, 24);
      const remaining = catTopics.length - 24;
      return (
        <section class="mb-12">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
                style={`background: ${cat.gradient}`}
              >
                {cat.emoji}
              </div>
              <div>
                <h2 class="font-display font-bold text-xl text-gray-900">{cat.name}</h2>
                <p class="text-gray-400 text-xs">{catTopics.length} topics</p>
              </div>
            </div>
            <a href={`/category/${cat.slug}`} class="text-brand hover:text-brand-dark text-sm font-semibold transition-colors">
              Browse {cat.offsCount} offers →
            </a>
          </div>

          <div class="flex flex-wrap gap-2">
            {shown.map(t => (
              <a
                href={`/topic/${t.slug}`}
                class="px-3.5 py-1.5 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 text-gray-600 hover:text-gray-900 text-sm rounded-lg transition-colors"
              >
                {t.name}
              </a>
            ))}
            {remaining > 0 && (
              <span class="px-3.5 py-1.5 bg-gray-100 text-gray-400 text-sm rounded-lg">
                +{remaining} more
              </span>
            )}
          </div>

          <div class="mt-4 h-px bg-gray-100"></div>
        </section>
      );
    })}
  </div>
</BaseLayout>
