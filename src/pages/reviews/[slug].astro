---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Newsletter from '../../components/Newsletter.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { offers, offerSlug, getAffiliateUrl } from '../../data/offers';
import { catalogOffers } from '../../data/catalog';
import { problemBySlug } from '../../data/problems';
import { categoryBySlug } from '../../data/categories';
import { getCollection } from 'astro:content';

// ── Build static paths from BOTH editorial and catalog offers ──────────────────
export function getStaticPaths() {
  const editorialPaths = offers
    .filter(o => o.approved)
    .map(o => ({
      params: { slug: offerSlug(o) },
      props: { type: 'editorial' as const, editorialOffer: o, catalogOffer: null },
    }));

  const catalogPaths = catalogOffers.map(o => ({
    params: { slug: o.slug },
    props: { type: 'catalog' as const, editorialOffer: null, catalogOffer: o },
  }));

  return [...editorialPaths, ...catalogPaths];
}

const { type, editorialOffer, catalogOffer } = Astro.props;

// ── Normalise to a display shape that works for both types ─────────────────────
const isEditorial = type === 'editorial';
const o = isEditorial ? editorialOffer! : catalogOffer!;

const shortName   = isEditorial ? editorialOffer!.shortName   : catalogOffer!.name.split(' - ')[0].trim();
const description = isEditorial ? editorialOffer!.description : catalogOffer!.description ?? '';
const geos        = o.geos;
const rateType    = isEditorial ? editorialOffer!.rateType     : catalogOffer!.payoutType;

// tagline: editorial has it; catalog synthesises from name
const tagline = isEditorial
  ? editorialOffer!.tagline
  : catalogOffer!.name.includes(' - ')
    ? catalogOffer!.name.split(' - ').slice(1).join(' - ')
    : catalogOffer!.description?.split('.')[0] ?? catalogOffer!.name;

const badge       = isEditorial ? editorialOffer!.badge       : undefined;
const trustSignal = isEditorial ? editorialOffer!.trustSignal : undefined;
const ctaText     = isEditorial ? editorialOffer!.ctaText     : `Visit ${shortName}`;
const ctaSubtext  = isEditorial ? editorialOffer!.ctaSubtext  : undefined;

// Affiliate URL
const affiliateUrl = isEditorial
  ? getAffiliateUrl(editorialOffer!)
  : catalogOffer!.trackingUrl;

// Related problem pages (editorial only)
const relatedProblems = isEditorial
  ? editorialOffer!.problems.map(p => problemBySlug[p]).filter(Boolean).slice(0, 3)
  : [];

// Category
const catSlug = isEditorial ? editorialOffer!.categories[0] : catalogOffer!.categorySlug;
const cat = categoryBySlug[catSlug];

// Related articles from the same category
const allArticles = await getCollection('articles');
function articleSlug(a: (typeof allArticles)[number]) {
  const parts = a.id.split('/');
  return parts[parts.length - 1].replace(/\.mdx?$/, '');
}
const relatedArticles = allArticles
  .filter(a => a.data.category === catSlug)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 3);

const rateLabel: Record<string, string> = {
  cps: 'Subscription',
  cpl: 'Free to try',
  cpa: 'One-time',
  revshare: 'Variable',
};

const geoDisplay = geos.includes('WW') || geos.length === 0
  ? 'Worldwide'
  : geos.slice(0, 6).join(', ');

const offerTypeLabel: Record<string, string> = {
  cps: 'a subscription product',
  cpl: 'a free lead — no purchase required to get started',
  cpa: 'a one-time purchase',
  revshare: 'a variable-cost product',
};

const faqs = [
  {
    q: `Is ${shortName} legit?`,
    a: `Yes. ${shortName} is a vetted offer verified through our affiliate network — available in ${geoDisplay}. We review all featured offers for legitimacy before listing them. Read the full terms on the provider's site before signing up, as pricing and cancellation terms vary by plan.`,
  },
  {
    q: `What is ${shortName} and how does it work?`,
    a: description
      ? `${description} ${trustSignal ? trustSignal + '.' : ''}`
      : `${shortName} is a partner offer available in ${geoDisplay} through the Verto affiliate catalog.`,
  },
  {
    q: `Who should use ${shortName}?`,
    a: `${shortName} is ${offerTypeLabel[rateType] ?? 'a partner offer'} best suited for people in ${geoDisplay} who ${description ? description.split('.')[0].replace(/^[A-Z]/, c => c.toLowerCase()) : 'need a solution in this category'}. It may not be the right fit if you need an immediate result with no commitment — confirm eligibility on the provider's site first.`,
  },
  {
    q: `Is ${shortName} available in my country?`,
    a: `${shortName} is currently available in: ${geoDisplay}. If your country isn't listed, the offer is not active for your location. Availability can change — check the provider's site for the most current geographic coverage.`,
  },
  {
    q: `What should I know before clicking through to ${shortName}?`,
    a: `The link on this page goes to the current ${shortName} offer page with live pricing. Pricing and availability can change. You are not committing to anything by clicking through. Review the billing and cancellation section on the provider's site before entering any payment information.`,
  },
].filter(f => f.a.trim());

const seoTitle    = `${shortName} Review 2026 — ${tagline.substring(0, 55)} | Verto`;
const seoDescription = `${shortName}: ${tagline}. Available in ${geoDisplay}. See how it works, who it's for, and how it compares.`;
---

<BaseLayout title={seoTitle} description={seoDescription} ogType="article" article={{ publishedTime: "2025-10-01", modifiedTime: new Date().toISOString().split('T')[0], author: "Verto Editorial Team", section: cat?.name ?? catSlug }}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": `${shortName} Review 2026`,
        "description": seoDescription,
        "datePublished": "2025-10-01",
        "dateModified": new Date().toISOString().split('T')[0],
        "image": {
          "@type": "ImageObject",
          "url": `https://verto.fun/og/${catSlug}.svg`,
          "width": 1200, "height": 628
        },
        "author": {
          "@type": "Person",
          "@id": "https://verto.fun/about#editorial-team",
          "name": "Verto Editorial Team",
          "url": "https://verto.fun/about",
          "worksFor": { "@type": "Organization", "@id": "https://verto.fun/#organization", "name": "Verto", "url": "https://verto.fun" }
        },
        "publisher": {
          "@type": "Organization",
          "name": "Verto",
          "url": "https://verto.fun",
          "logo": { "@type": "ImageObject", "url": "https://verto.fun/favicon.svg" }
        },
        "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href },
      },
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        })),
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",   "item": "https://verto.fun" },
          { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://verto.fun/reviews" },
          cat ? { "@type": "ListItem", "position": 3, "name": cat.name, "item": `https://verto.fun/${catSlug}/` } : null,
          { "@type": "ListItem", "position": cat ? 4 : 3, "name": shortName, "item": Astro.url.href },
        ].filter(Boolean),
      },
    ],
  })} />

  <!-- Disclosure banner -->
  <div class="bg-amber-50 border-b border-amber-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-2 text-center">
      <p class="text-xs text-amber-700">
        <strong>Advertising Disclosure:</strong> Verto may earn a commission when you click links on this page, at no extra cost to you.
        <a href="/about#disclosure" class="underline hover:text-amber-900">Learn more</a>
      </p>
    </div>
  </div>

  <!-- Hero -->
  <div class="bg-slate-900 py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-white/40 text-xs mb-6 flex-wrap">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/reviews" class="hover:text-white transition-colors">Reviews</a>
        {cat && <><span>/</span><a href={`/${catSlug}/`} class="hover:text-white transition-colors">{cat.name}</a></>}
        <span>/</span>
        <span class="text-white/60">{shortName}</span>
      </nav>

      <div class="flex items-start gap-3 mb-4 flex-wrap">
        {badge && (
          <span class="bg-brand text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">
            {badge}
          </span>
        )}
        <span class="text-white/40 text-sm font-medium uppercase tracking-widest pt-0.5">
          {cat?.name ?? 'Offer'} · Verto Review
        </span>
      </div>

      <!-- Eyebrow -->
      <p class="text-white/40 text-xs font-bold uppercase tracking-widest mb-3">
        {cat?.name ?? 'Offer'} · Verto Review · {new Date().getFullYear()}
      </p>

      <h1 class="font-display text-3xl md:text-4xl font-black text-white mb-3 leading-tight">
        {shortName}: {tagline.length > 85 ? tagline.substring(0, 85).replace(/\s\S+$/, '') + '…' : tagline}
      </h1>
      <p class="text-white/75 text-lg mb-4 max-w-2xl leading-relaxed font-medium">
        {tagline.length > 100 ? tagline.substring(0, 100) + '…' : tagline}
      </p>
      <p class="text-white/50 text-base mb-8 max-w-2xl leading-relaxed">
        {description
          ? `Here's what to know before you sign up: how ${shortName} works, who it's actually a good fit for, and what to check before committing.`
          : `Here's what to know before you sign up — pricing, how it works, and who should actually use it.`}
      </p>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href={affiliateUrl}
          rel="sponsored noopener"
          target="_blank"
          class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-bold px-7 py-3.5 rounded-xl transition-colors text-base"
        >
          {isEditorial ? ctaText : rateType === 'cpl' ? `Check If You Qualify — Free →` : rateType === 'cps' ? `See Current Subscription Pricing →` : `Check Current Pricing →`}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <p class="text-white/35 text-sm">No obligation — checking availability doesn't commit you to anything</p>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <!-- Quick stats -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-12 p-6 bg-gray-50 rounded-2xl border border-gray-100">
      <div class="text-center">
        <p class="text-xs text-gray-400 uppercase tracking-widest font-medium mb-1">Category</p>
        <p class="font-semibold text-gray-800 text-sm">{cat?.name ?? catSlug}</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-gray-400 uppercase tracking-widest font-medium mb-1">Available In</p>
        <p class="font-semibold text-gray-800 text-sm">{geoDisplay}</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-gray-400 uppercase tracking-widest font-medium mb-1">Offer Type</p>
        <p class="font-semibold text-gray-800 text-sm capitalize">{rateLabel[rateType] ?? rateType}</p>
      </div>
    </div>

    <!-- Description -->
    <div class="mb-10">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-4">What is {shortName}?</h2>
      <p class="text-gray-600 text-lg leading-relaxed">
        {description || `${shortName} is a partner offer available in ${geoDisplay}.`}
      </p>
      {trustSignal && (
        <div class="mt-5 flex items-center gap-3 p-4 bg-brand/5 border border-brand/20 rounded-xl">
          <svg class="w-5 h-5 text-brand shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-gray-700 font-medium">{trustSignal}</p>
        </div>
      )}
    </div>

    <!-- Inline CTA -->
    <div class="flex items-center justify-between gap-4 p-5 bg-green-50 border-2 border-green-200 rounded-2xl shadow-sm mb-12">
      <div>
        <p class="font-display font-bold text-gray-900">{shortName}</p>
        <p class="text-sm text-gray-500 line-clamp-1">Available in {geoDisplay} · No obligation to proceed</p>
      </div>
      <a
        href={affiliateUrl}
        rel="sponsored noopener"
        target="_blank"
        class="shrink-0 bg-cta hover:bg-cta-dark text-white font-bold px-5 py-2.5 rounded-xl text-sm transition-colors whitespace-nowrap"
      >
        {isEditorial ? ctaText : rateType === 'cpl' ? `Check Eligibility — Free →` : `See Pricing →`}
      </a>
    </div>

    <!-- Related problem pages (editorial offers only) -->
    {relatedProblems.length > 0 && (
      <div class="mb-12">
        <h2 class="font-display font-bold text-2xl text-gray-900 mb-2">
          Common Reasons People Choose {shortName}
        </h2>
        <p class="text-gray-500 mb-6">See our full guides — with comparisons and alternatives.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProblems.map(problem => (
            <a
              href={`/best/${problem.slug}`}
              class="group p-5 bg-white border border-gray-100 rounded-2xl hover:border-brand/30 hover:shadow-md transition-all"
            >
              <div class="text-2xl mb-2">{problem.emoji}</div>
              <p class="font-semibold text-gray-900 group-hover:text-brand transition-colors text-sm leading-snug">
                {problem.headline.split('?')[0]}?
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Who it's for / who should skip it -->
    <div class="mb-12 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-green-50 border border-green-200 rounded-2xl p-5">
        <p class="eyebrow text-green-700 mb-3">Good fit if you…</p>
        <ul class="flex flex-col gap-2 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Want to compare options before committing to anything</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Are located in {geoDisplay} (where this offer is active)</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Have read at least one other option and want a specific comparison</span>
          </li>
        </ul>
      </div>
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5">
        <p class="eyebrow text-gray-500 mb-3">May not be right if you…</p>
        <ul class="flex flex-col gap-2 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>Need an immediate result with no waiting period</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>Are not located in {geoDisplay}</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>Have a specific requirement — check the provider's site for exact eligibility details</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mb-12">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-6">
        Frequently Asked Questions about {shortName}
      </h2>
      <div class="flex flex-col gap-4">
        {faqs.map(faq => (
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none hover:bg-gray-50 transition-colors">
              <h3 class="font-semibold text-gray-900 text-base leading-snug">{faq.q}</h3>
              <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="rounded-3xl bg-slate-900 p-8 md:p-10 text-center mb-12">
      <p class="text-white/50 text-sm uppercase tracking-widest font-semibold mb-2">Check availability first</p>
      <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-3">{shortName}</h2>
      <p class="text-white/60 mb-6 max-w-md mx-auto leading-relaxed">{tagline.length > 120 ? tagline.substring(0, 120) + '…' : tagline}</p>
      <!-- Trust badges -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
        <span class="flex items-center gap-1.5 text-white/50 text-xs font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
          SSL Secure
        </span>
        <span class="flex items-center gap-1.5 text-white/50 text-xs font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          No commitment required
        </span>
        <span class="flex items-center gap-1.5 text-white/50 text-xs font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Free to check pricing
        </span>
      </div>
      <a
        href={affiliateUrl}
        rel="sponsored noopener"
        target="_blank"
        class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-bold px-8 py-4 rounded-2xl text-base transition-colors min-h-[56px]"
      >
        {isEditorial ? ctaText : rateType === 'cpl' ? `Check If You Qualify for ${shortName} — Free →` : `See ${shortName} Pricing and Availability →`}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      <p class="text-white/30 text-xs mt-3">Sponsored · Clicking through doesn't commit you to a purchase</p>
    </div>

    <!-- Related Reading -->
    {relatedArticles.length > 0 && (
      <div class="mt-12 mb-4">
        <div class="flex items-center justify-between mb-5">
          <h2 class="font-display font-bold text-2xl text-gray-900">Related Guides</h2>
          {cat && (
            <a href={`/${catSlug}/`} class="text-sm font-semibold text-brand hover:text-brand-dark transition-colors">
              All {cat.name} guides →
            </a>
          )}
        </div>
        <div class="grid gap-5 sm:grid-cols-3">
          {relatedArticles.map(a => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              slug={articleSlug(a)}
              author={a.data.author}
              date={a.data.date}
              readTime={a.data.readTime}
              sponsored={a.data.sponsored}
            />
          ))}
        </div>
      </div>
    )}

    <Newsletter />

    <!-- Legal -->
    <div class="mt-10 p-5 bg-gray-50 rounded-2xl border border-gray-100">
      <p class="text-xs text-gray-400 leading-relaxed">
        <strong class="text-gray-500">Advertising Disclosure:</strong> This page contains affiliate links. Verto may receive a commission when you purchase through these links, at no additional cost to you. We only feature offers we believe provide genuine value. Individual results vary. Always review full terms on the provider's website before completing any purchase or registration.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  details[open] summary { background-color: rgb(249 250 251); }
</style>
