---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Newsletter from '../../components/Newsletter.astro';
import { offers, offerSlug, getAffiliateUrl } from '../../data/offers';
import { categoryBySlug } from '../../data/categories';

const approved = offers.filter(o => o.approved);

const byCategory = approved.reduce((acc, o) => {
  const cat = o.categories[0] ?? 'other';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(o);
  return acc;
}, {} as Record<string, typeof offers>);

const catEntries = Object.entries(byCategory).sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout
  title="Verto Reviews — Every Product We've Tested and Currently Recommend"
  description={`Verto's complete product and service index — ${approved.length} offers across health, finance, privacy, legal, and lifestyle. Each one has been assessed and verified before we link to it.`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "name": `Verto Reviews — Products and Services We Currently Recommend`,
        "description": `Verto's complete index of assessed products and services across health, finance, privacy, legal, and lifestyle categories.`,
        "url": "https://verto.fun/reviews",
        "publisher": { "@type": "Organization", "name": "Verto", "url": "https://verto.fun" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://verto.fun" },
          { "@type": "ListItem", "position": 2, "name": "All Reviews", "item": "https://verto.fun/reviews" }
        ]
      }
    ]
  })} />

  <div class="bg-slate-900 py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <p class="text-brand text-sm font-semibold uppercase tracking-widest mb-3">Product Index</p>
      <h1 class="font-display text-3xl md:text-4xl font-black text-white mb-3">
        What Verto Currently Recommends
      </h1>
      <p class="text-white/60 text-lg max-w-xl">
        Every product and service we cover — tested and assessed before we publish. Browse by category or jump to a guide for a direct verdict.
      </p>
    </div>
  </div>

  <div class="bg-white border-b border-gray-100 sticky top-16 z-40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-2 overflow-x-auto">
      <a href="#all" class="shrink-0 text-xs font-semibold uppercase tracking-wide px-3 py-1.5 rounded-full bg-brand text-white">
        All ({approved.length})
      </a>
      {catEntries.map(([catSlug, catOffers]) => {
        const cat = categoryBySlug[catSlug];
        return (
          <a
            href={`#${catSlug}`}
            class="shrink-0 text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors whitespace-nowrap"
          >
            {cat?.name ?? catSlug} ({catOffers.length})
          </a>
        );
      })}
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12" id="all">
    {catEntries.map(([catSlug, catOffers]) => {
      const cat = categoryBySlug[catSlug];
      return (
        <div class="mb-14" id={catSlug}>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center text-sm font-bold text-gray-500 shrink-0">{(cat?.name ?? catSlug).charAt(0).toUpperCase()}</span>
            <div>
              <h2 class="font-display font-bold text-xl text-gray-900">{cat?.name ?? catSlug}</h2>
              <p class="text-gray-400 text-sm">{catOffers.length} reviewed</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {catOffers.map(offer => (
              <div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-md hover:border-gray-200 transition-all">
                <div class="p-5">
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <div>
                      <p class="font-display font-bold text-gray-900 leading-tight">{offer.shortName}</p>
                      <p class="text-xs text-gray-400 mt-0.5">{offer.geos.join(', ')}</p>
                    </div>
                    {offer.badge && (
                      <span class="shrink-0 text-xs font-bold px-2 py-1 bg-brand/10 text-brand rounded-full">
                        {offer.badge}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-gray-600 leading-snug mb-4 line-clamp-2">{offer.tagline}</p>
                  {offer.trustSignal && (
                    <p class="text-xs text-gray-400 mb-4 flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      {offer.trustSignal}
                    </p>
                  )}
                  <div class="flex items-center gap-2">
                    <a
                      href={getAffiliateUrl(offer)}
                      rel="sponsored noopener"
                      target="_blank"
                      class="flex-1 bg-brand hover:bg-brand-dark text-white text-xs font-bold py-2.5 px-4 rounded-xl text-center transition-colors"
                    >
                      {offer.ctaText}
                    </a>
                    <a
                      href={`/reviews/${offerSlug(offer)}`}
                      class="px-3 py-2.5 border border-gray-200 rounded-xl text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors"
                      title="Read review"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}

    <Newsletter />

    <div class="mt-8 p-5 bg-gray-50 rounded-2xl border border-gray-100">
      <p class="text-xs text-gray-400 leading-relaxed">
        <strong class="text-gray-500">Advertising Disclosure:</strong> Verto earns a commission when you click affiliate links on this page, at no extra cost to you. Offers are vetted before inclusion. Individual results vary.
        <a href="/about#disclosure" class="underline hover:text-gray-600 ml-1">Full disclosure →</a>
      </p>
    </div>
  </div>
</BaseLayout>
