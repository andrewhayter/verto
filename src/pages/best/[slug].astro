---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OfferCard from '../../components/OfferCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import { problems, problemBySlug } from '../../data/problems';
import { offersByProblem, offers as allOffers, getAffiliateUrl } from '../../data/offers';
import { categoryBySlug } from '../../data/categories';

export async function getStaticPaths() {
  return problems.map(p => ({
    params: { slug: p.slug },
    props: { problem: p },
  }));
}

const { problem } = Astro.props;
const cat = categoryBySlug[problem.category];

const problemOffers = (offersByProblem[problem.slug] ?? []).filter(o => o.approved);
const topOffer = problemOffers[0];
---

<BaseLayout
  title={problem.seoTitle}
  description={problem.seoDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": problem.headline,
        "description": problem.seoDescription,
        "datePublished": "2026-05-01",
        "dateModified": "2026-06-11",
        "image": {
          "@type": "ImageObject",
          "url": `https://verto.pages.dev/og/${problem.category}.png`,
          "width": 1200,
          "height": 628
        },
        "author": {
          "@type": "Person",
          "name": "Verto Editorial Team",
          "url": "https://verto.pages.dev/about",
          "worksFor": { "@type": "Organization", "name": "Verto", "url": "https://verto.pages.dev" }
        },
        "publisher": {
          "@type": "Organization",
          "name": "Verto",
          "url": "https://verto.pages.dev",
          "logo": { "@type": "ImageObject", "url": "https://verto.pages.dev/favicon.svg" }
        },
        "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href },
      },
      {
        "@type": "FAQPage",
        "mainEntity": problem.faqs.map(faq => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": { "@type": "Answer", "text": faq.a },
        })),
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://verto.pages.dev" },
          { "@type": "ListItem", "position": 2, "name": cat?.name ?? "Offers", "item": `https://verto.pages.dev/${problem.category}/` },
          { "@type": "ListItem", "position": 3, "name": problem.headline.substring(0, 60), "item": Astro.url.href },
        ],
      },
    ],
  })} />

  <div class="bg-amber-50 border-b border-amber-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-2 text-center">
      <p class="text-xs text-amber-700">
        <strong>Advertising Disclosure:</strong> Verto may earn a commission when you click links on this page, at no extra cost to you.
        <a href="/about#disclosure" class="underline hover:text-amber-900">Learn more</a>
      </p>
    </div>
  </div>

  <div class="relative py-14 md:py-20 overflow-hidden" style={`background: ${problem.gradient}`}>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-white/50 text-xs mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        {cat && <a href={`/${cat.slug}/`} class="hover:text-white transition-colors">{cat.name}</a>}
        {cat && <span>/</span>}
        <span class="text-white/70">Solution Guide</span>
      </nav>

      <div class="text-5xl mb-4">{problem.emoji}</div>
      <h1 class="font-display text-3xl md:text-5xl font-black text-white leading-tight mb-5 max-w-3xl">
        {problem.headline}
      </h1>
      <p class="text-white/80 text-lg md:text-xl mb-8 max-w-2xl leading-relaxed">
        {problem.subheadline}
      </p>

      <div class="flex flex-wrap gap-6">
        {problem.trustStats.map(ts => (
          <div class="text-center">
            <div class="font-display font-black text-2xl md:text-3xl text-white">{ts.stat}</div>
            <div class="text-white/60 text-xs mt-0.5 max-w-[120px]">{ts.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {topOffer && (
    <div class="bg-white border-b border-gray-100 shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl shrink-0" style={`background: ${problem.gradient}`}>
              {problem.emoji}
            </div>
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-widest mb-0.5">Top Recommendation</p>
              <p class="font-display font-bold text-gray-900">{topOffer.shortName} — {topOffer.tagline}</p>
            </div>
          </div>
          <a
            href={getAffiliateUrl(topOffer, problem.slug)}
            rel="sponsored noopener"
            target="_blank"
            class="shrink-0 bg-brand hover:bg-brand-dark text-white font-bold px-6 py-3 rounded-xl text-sm transition-colors whitespace-nowrap"
          >
            {topOffer.ctaText} →
          </a>
        </div>
      </div>
    </div>
  )}

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 mb-8">
      <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-2">Bottom Line</p>
      <p class="text-gray-800 font-medium leading-snug">{problem.subheadline}</p>
    </div>

    <div class="prose-verto mb-10">
      <p class="text-xl text-gray-700 leading-relaxed font-medium italic border-l-4 border-brand pl-5">
        "{problem.hook}"
      </p>
      <p class="mt-5 text-gray-600 text-lg leading-relaxed">{problem.description}</p>
    </div>

    {problem.facebookHook && (
      <div class="flex items-start gap-3 p-5 bg-brand/5 border-l-4 border-brand rounded-r-2xl mb-10">
        <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
        <p class="text-gray-800 font-semibold leading-snug">{problem.facebookHook}</p>
      </div>
    )}

    {problemOffers.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-7 bg-brand rounded-full"></div>
          <h2 class="font-display font-bold text-2xl text-gray-900">
            {problemOffers.length} Verified Option{problemOffers.length !== 1 ? 's' : ''} — Ranked by Evidence and Value
          </h2>
        </div>

        {problemOffers[0] && (
          <div class="mb-6">
            <OfferCard offer={problemOffers[0]} rank={1} problemSlug={problem.slug} variant="featured" />
          </div>
        )}

        {problemOffers.length > 1 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {problemOffers.slice(1).map((offer, i) => (
              <OfferCard offer={offer} rank={i + 2} problemSlug={problem.slug} variant="full" />
            ))}
          </div>
        )}
      </div>
    )}

    <div class="bg-gray-50 rounded-2xl p-6 md:p-8 mb-12">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-4">
        By the Numbers: {problem.trustStats.map(ts => ts.stat).join(' · ')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {problem.trustStats.map(ts => (
          <div class="text-center">
            <div class="font-display font-black text-3xl text-brand mb-1">{ts.stat}</div>
            <div class="text-sm text-gray-600">{ts.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="mb-12">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {problem.faqs.map((faq, i) => (
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none hover:bg-gray-50 transition-colors">
              <h3 class="font-semibold text-gray-900 text-base leading-snug">{faq.q}</h3>
              <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    {topOffer && (
      <div class="rounded-3xl overflow-hidden mb-12" style={`background: ${problem.gradient}`}>
        <div class="bg-black/40 p-8 md:p-10 text-center">
          <p class="text-white/70 text-sm uppercase tracking-widest font-semibold mb-2">Ready to solve this?</p>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-3">
            {topOffer.shortName} — {topOffer.tagline}
          </h2>
          {topOffer.trustSignal && (
            <p class="text-white/70 mb-6">{topOffer.trustSignal}</p>
          )}
          <a
            href={getAffiliateUrl(topOffer, problem.slug)}
            rel="sponsored noopener"
            target="_blank"
            class="inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-gray-900 font-bold px-8 py-4 rounded-2xl text-base transition-colors"
          >
            {topOffer.ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          {topOffer.ctaSubtext && (
            <p class="text-white/60 text-sm mt-3">{topOffer.ctaSubtext}</p>
          )}
        </div>
      </div>
    )}

    <Newsletter />

    <div class="mt-10 p-5 bg-gray-50 rounded-2xl border border-gray-100">
      <p class="text-xs text-gray-400 leading-relaxed">
        <strong class="text-gray-500">Advertising Disclosure:</strong> This page contains affiliate links. Verto may receive a commission when you purchase through these links, at no additional cost to you. We only feature offers we believe are genuinely useful to our readers. Individual results vary. Consult a qualified professional before starting any health, financial, or legal program.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  details[open] summary { background-color: rgb(249 250 251); }
</style>
