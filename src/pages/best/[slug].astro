---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OfferCard from '../../components/OfferCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import QuizEntry from '../../components/QuizEntry.astro';
import SocialProofBlock from '../../components/SocialProofBlock.astro';
import StickyCtaBar from '../../components/StickyCtaBar.astro';
import ScrollTracker from '../../components/ScrollTracker.astro';
import { problems } from '../../data/problems';
import { offersByProblem, getAffiliateUrl } from '../../data/offers';
import { categoryBySlug } from '../../data/categories';
import { getCollection } from 'astro:content';
import type { Comment } from '../../components/SocialProofBlock.astro';

export async function getStaticPaths() {
  return problems.map(p => ({
    params: { slug: p.slug },
    props: { problem: p },
  }));
}

const { problem } = Astro.props;
const cat = categoryBySlug[problem.category];

const allArticles = await getCollection('articles');
function articleSlug(a: (typeof allArticles)[number]) {
  const parts = a.id.split('/');
  return parts[parts.length - 1].replace(/\.mdx?$/, '');
}
const relatedArticles = allArticles
  .filter(a => a.data.category === problem.category)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 3);

// Show all offers for this problem (approved = tracking link, non-approved = direct landingPage)
const problemOffers = offersByProblem[problem.slug] ?? [];
const topOffer = problemOffers[0];

const eyebrowDate = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(new Date());

/* Social proof comments per category */
const commentsByCat: Record<string, Comment[]> = {
  'health-wellness': [
    { name: "Jennifer M.", location: "Winnipeg, MB", initials: "JM", bgColor: "#7c3aed", ago: "3 days ago",  helpful: 342, text: "I was so skeptical after years of trying everything. But 3 months in and I've lost 22 lbs. Wish I'd found this a year ago." },
    { name: "Sandra K.",   location: "Ottawa, ON",   initials: "SK", bgColor: "#2563eb", ago: "5 days ago",  helpful: 218, text: "My doctor mentioned GLP-1 but the cost through insurance was prohibitive. Found a telehealth option under $200/month. Game-changer." },
    { name: "Mike T.",     location: "Calgary, AB",  initials: "MT", bgColor: "#b45309", ago: "2 weeks ago", helpful: 156, text: "Tried keto, intermittent fasting, all of it. The biological approach finally made things click. Down 18 lbs in 8 weeks." },
  ],
  financial: [
    { name: "David R.",  location: "Toronto, ON",  initials: "DR", bgColor: "#047857", ago: "2 days ago",  helpful: 412, text: "Had 4 credit cards at 22% APR. The consolidation tool got me to 11.9% and monthly payments dropped $340. Took 3 minutes." },
    { name: "Amanda S.", location: "Vancouver, BC", initials: "AS", bgColor: "#9333ea", ago: "5 days ago",  helpful: 287, text: "Only soft pulls, so no credit score impact. Got matched with 3 lenders instantly. Ended up with $8,500 at 14% for a home repair." },
    { name: "Kevin O.",  location: "Montréal, QC",  initials: "KO", bgColor: "#be185d", ago: "1 week ago",  helpful: 189, text: "All 3 options they showed were available in Quebec. Very straightforward process." },
  ],
  'antivirus-vpn': [
    { name: "Alex P.",   location: "Edmonton, AB",  initials: "AP", bgColor: "#2563eb", ago: "4 days ago",  helpful: 203, text: "Switched from a VPN that slowed my connection by 40% to one that actually performs. Night and day for streaming." },
    { name: "Rachel L.", location: "Vancouver, BC", initials: "RL", bgColor: "#7c3aed", ago: "1 week ago",  helpful: 167, text: "The 6-device plan covers all our phones and laptops. Finally stopped worrying about public WiFi." },
    { name: "James M.",  location: "Toronto, ON",   initials: "JM", bgColor: "#047857", ago: "2 weeks ago", helpful: 145, text: "My ISP was throttling me. After the VPN, Netflix went from buffering SD to smooth 4K. Worth every penny." },
  ],
  insurance: [
    { name: "Patricia W.", location: "Hamilton, ON",    initials: "PW", bgColor: "#c2410c", ago: "3 days ago",  helpful: 298, text: "Saved $780 on my annual premium just by using the comparison tool. 5 minutes, better coverage than my old policy." },
    { name: "Tyler B.",    location: "Calgary, AB",     initials: "TB", bgColor: "#1d4ed8", ago: "6 days ago",  helpful: 234, text: "After a fender-bender my rates jumped 40%. This tool found 4 providers who didn't penalize me as hard." },
    { name: "Maria S.",    location: "Mississauga, ON", initials: "MS", bgColor: "#b45309", ago: "1 week ago",  helpful: 176, text: "New driver. Everyone said insurance would be brutal. Found a rate 30% lower than my parents' broker quoted." },
  ],
};

const defaultComments: Comment[] = [
  { name: "Sarah B.",   location: "Toronto, ON",   initials: "SB", bgColor: "#7c3aed", ago: "3 days ago",  helpful: 289, text: "Really thorough breakdown. Saved hours of research and I'm confident I made the right choice." },
  { name: "Michael C.", location: "Vancouver, BC", initials: "MC", bgColor: "#047857", ago: "1 week ago",  helpful: 234, text: "Honest about pros and cons. Most sites just push whatever pays the most commission." },
  { name: "Lisa T.",    location: "Ottawa, ON",    initials: "LT", bgColor: "#be185d", ago: "2 weeks ago", helpful: 178, text: "Shared this with three friends who needed the same info. The comparison made everything clear." },
];

const socialComments = commentsByCat[problem.category] ?? defaultComments;

const pageViews = 18400 + Math.abs(problem.slug.length * 137 + problem.headline.length * 53) % 8000;

/* Named author per category — mirrors ArticleLayout mapping */
const categoryAuthor: Record<string, { name: string; jobTitle: string; initials: string; color: string }> = {
  'health-wellness':  { name: 'Elena Park',      jobTitle: 'Health & Wellness Editor',           initials: 'EP', color: '#7c3aed' },
  financial:          { name: 'Sofia Reyes',      jobTitle: 'Personal Finance Editor',             initials: 'SR', color: '#9333ea' },
  'antivirus-vpn':    { name: 'Alex Kovacs',      jobTitle: 'Security & Technology Editor',        initials: 'AK', color: '#2563eb' },
  insurance:          { name: 'Thomas Walsh',     jobTitle: 'Legal Services & Insurance Editor',   initials: 'TW', color: '#1d4ed8' },
  travel:             { name: 'Maya Okonkwo',     jobTitle: 'Travel Editor',                       initials: 'MO', color: '#b45309' },
  surveys:            { name: 'Priya Nair',       jobTitle: 'Side Income & Surveys Editor',        initials: 'PN', color: '#c2410c' },
};
const pageAuthor = categoryAuthor[problem.category] ?? { name: 'Verto Editorial Team', jobTitle: 'Contributing Editor', initials: 'VE', color: '#64748b' };
---

<BaseLayout
  title={problem.seoTitle}
  description={problem.seoDescription}
  ogType="article"
  article={{
    publishedTime: "2025-10-01",
    modifiedTime: new Date().toISOString().split('T')[0],
    author: pageAuthor.name,
    section: cat?.name ?? problem.category,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": problem.headline,
        "description": problem.seoDescription,
        "datePublished": "2025-10-01",
        "dateModified": new Date().toISOString().split('T')[0],
        "image": {
          "@type": "ImageObject",
          "url": `https://verto.fun/og/${problem.category}.svg`,
          "width": 1200,
          "height": 628
        },
        "author": {
          "@type": "Person",
          "@id": `https://verto.fun/about#${pageAuthor.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`,
          "name": pageAuthor.name,
          "jobTitle": pageAuthor.jobTitle,
          "url": "https://verto.fun/about",
          "worksFor": { "@type": "Organization", "@id": "https://verto.fun/#organization", "name": "Verto" }
        },
        "publisher": {
          "@type": "Organization",
          "name": "Verto",
          "url": "https://verto.fun",
          "logo": { "@type": "ImageObject", "url": "https://verto.fun/favicon.svg" }
        },
        "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href }
      },
      {
        "@type": "FAQPage",
        "mainEntity": problem.faqs.map(faq => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": { "@type": "Answer", "text": faq.a }
        }))
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://verto.fun" },
          { "@type": "ListItem", "position": 2, "name": cat?.name ?? "Offers", "item": `https://verto.fun/${problem.category}/` },
          { "@type": "ListItem", "position": 3, "name": problem.headline.substring(0, 60), "item": Astro.url.href }
        ]
      }
    ]
  })} />

  <!-- Disclosure -->
  <div class="bg-amber-50 border-b border-amber-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-2 text-center">
      <p class="text-xs text-amber-700">
        <strong>Advertising Disclosure:</strong> Verto may earn a commission when you click links on this page, at no extra cost to you.
        <a href="/about#disclosure" class="underline hover:text-amber-900">Learn more</a>
      </p>
    </div>
  </div>

  <!-- ============================
       HERO — UTM-AWARE HEADLINE
       ============================ -->
  <div class="relative py-14 md:py-20 overflow-hidden" style={`background: ${problem.gradient}`} data-hero-sentinel>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/50 text-xs mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        {cat && <a href={`/${cat.slug}/`} class="hover:text-white transition-colors">{cat.name}</a>}
        {cat && <span>/</span>}
        <span class="text-white/70">Solution Guide</span>
      </nav>

      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-4">
        <span class="eyebrow text-white/60">{cat?.name ?? problem.category}</span>
        <span class="text-white/20">|</span>
        <span class="eyebrow text-white/60">{eyebrowDate}</span>
        <span class="text-white/20">|</span>
        <span class="eyebrow bg-white/15 text-white/80 px-2 py-0.5 rounded">
          {pageViews.toLocaleString()} readers this month
        </span>
      </div>

      <!-- Author byline (trust + editorial authority) -->
      <div class="flex items-center gap-2.5 mb-5">
        <div
          class="w-8 h-8 rounded-full shrink-0 flex items-center justify-center text-white text-xs font-bold"
          style={`background-color: ${pageAuthor.color};`}
          aria-label={`Author: ${pageAuthor.name}`}
        >
          {pageAuthor.initials}
        </div>
        <div>
          <p class="text-white/80 text-sm font-semibold leading-none">{pageAuthor.name}</p>
          <p class="text-white/45 text-xs mt-0.5">{pageAuthor.jobTitle}</p>
        </div>
      </div>

      <!-- UTM-aware H1 -->
      <h1
        id="utm-headline"
        data-default-headline={problem.headline}
        data-pain-headline={problem.hook || problem.headline}
        data-social-headline={problem.facebookHook || problem.headline}
        class="font-display text-3xl md:text-5xl font-black text-white leading-tight mb-5 max-w-3xl"
      >
        {problem.headline}
      </h1>

      <p class="text-white/80 text-lg md:text-xl mb-8 max-w-2xl leading-relaxed">
        {problem.subheadline}
      </p>

      <!-- Trust stats -->
      <div class="flex flex-wrap gap-6">
        {problem.trustStats.map(ts => (
          <div class="text-center">
            <div class="font-display font-black text-2xl md:text-3xl text-white">{ts.stat}</div>
            <div class="text-white/60 text-xs mt-0.5 max-w-[120px]">{ts.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ============================
       EDITORIAL CONTENT BODY
       ============================ -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">

    <!-- Hook narrative — 3-paragraph PAS opening (Problem → Agitation → Stakes) -->
    <div class="mb-10 space-y-5">
      <!-- Para 1: Problem identity — hook as narrative opener, not pullquote -->
      <p class="text-xl text-gray-800 font-semibold leading-snug">
        {problem.hook}
      </p>

      <!-- Para 2: Agitation — description expands the problem, not the solution -->
      <p class="text-gray-600 text-lg leading-relaxed">{problem.description}</p>

      <!-- Para 3: Stakes — subheadline as the "what changes if you get this right" bridge -->
      <div class="border-l-4 border-brand pl-5 py-1">
        <p class="text-gray-700 text-base leading-relaxed font-medium">{problem.subheadline}</p>
      </div>
    </div>

    <!-- Social proof — after hook (Agitation) -->
    <SocialProofBlock
      comments={socialComments}
      title="What People In This Situation Say"
    />

    <!-- Discovery pivot — Solution introduction -->
    {problem.facebookHook && (
      <div class="my-10 rounded-2xl bg-blue-50 border border-blue-100 p-6">
        <p class="eyebrow text-blue-600 mb-2">What We Found</p>
        <p class="text-gray-800 font-semibold leading-relaxed text-lg">{problem.facebookHook}</p>
      </div>
    )}

    <!-- Mechanism section — WHY this works (surfaces FAQ[0] as editorial content before the sell) -->
    {problem.faqs.length > 0 && (
      <div class="my-10 bg-white border border-gray-100 rounded-2xl p-6 md:p-8 shadow-sm">
        <p class="eyebrow text-brand mb-2">How It Works</p>
        <h2 class="font-display font-bold text-xl text-gray-900 mb-3">{problem.faqs[0].q}</h2>
        <p class="text-gray-600 leading-relaxed">{problem.faqs[0].a}</p>
      </div>
    )}

    <!-- Quiz / multi-step entry — NO hard sell above this point -->
    {topOffer && (
      <QuizEntry
        headline="See Which Option Fits Your Situation"
        offerName={topOffer.shortName}
        ctaUrl={getAffiliateUrl(topOffer, problem.slug)}
        ctaText={topOffer.ctaText}
        category={problem.category}
        subtext={topOffer.ctaSubtext}
      />
    )}

    <!-- Verified offers section -->
    {problemOffers.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-7 bg-brand rounded-full"></div>
          <h2 class="font-display font-bold text-2xl text-gray-900">
            {problemOffers.length} Option{problemOffers.length !== 1 ? 's' : ''} — Compared on Price, Evidence, and Fit
          </h2>
        </div>

        {problemOffers[0] && (
          <div class="mb-6">
            <OfferCard offer={problemOffers[0]} rank={1} problemSlug={problem.slug} variant="featured" />
          </div>
        )}

        {problemOffers.length > 1 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {problemOffers.slice(1).map((offer, i) => (
              <OfferCard offer={offer} rank={i + 2} problemSlug={problem.slug} variant="full" />
            ))}
          </div>
        )}
      </div>
    )}

    <!-- By the numbers -->
    <div class="bg-gray-50 rounded-2xl p-6 md:p-8 mb-12">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-6">
        By the Numbers
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {problem.trustStats.map(ts => (
          <div class="text-center">
            <div class="font-display font-black text-3xl text-brand mb-1">{ts.stat}</div>
            <div class="text-sm text-gray-600 leading-snug">{ts.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- FAQ — conversion objections framed as questions -->
    <div class="mb-12">
      <h2 class="font-display font-bold text-2xl text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        {problem.faqs.map((faq) => (
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none hover:bg-gray-50 transition-colors">
              <h3 class="font-semibold text-gray-900 text-base leading-snug">{faq.q}</h3>
              <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- Final CTA block with trust signals -->
    {topOffer && (
      <div class="rounded-3xl overflow-hidden mb-12" style={`background: ${problem.gradient}`}>
        <div class="bg-black/40 p-8 md:p-10 text-center">
          <p class="eyebrow text-white/60 mb-2">Ready to solve this?</p>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-2">
            {topOffer.shortName} — {topOffer.tagline}
          </h2>
          {topOffer.trustSignal && (
            <p class="text-white/70 mb-6">{topOffer.trustSignal}</p>
          )}
          <!-- Trust badges -->
          <div class="flex items-center justify-center gap-4 mb-6 flex-wrap">
            <span class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              SSL Secured
            </span>
            <span class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              No Obligation
            </span>
            <span class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Check takes under 2 min
            </span>
          </div>
          <a
            href={getAffiliateUrl(topOffer, problem.slug)}
            rel="sponsored noopener"
            target="_blank"
            data-cta-click="problem-final"
            class="inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-gray-900 font-bold px-8 py-4 rounded-2xl text-base transition-colors min-h-[56px]"
          >
            See if you qualify →
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <p class="text-white/50 text-sm mt-3">No commitment — checking takes under 2 minutes</p>
        </div>
      </div>
    )}

    <!-- Related Reading -->
    {relatedArticles.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center justify-between mb-5">
          <h2 class="font-display font-bold text-2xl text-gray-900">Go Deeper</h2>
          <a href={`/${problem.category}/`} class="text-sm font-semibold text-brand hover:text-brand-dark transition-colors">
            All {cat?.name ?? 'category'} guides →
          </a>
        </div>
        <div class="grid gap-5 sm:grid-cols-3">
          {relatedArticles.map(a => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              slug={articleSlug(a)}
              author={a.data.author}
              date={a.data.date}
              readTime={a.data.readTime}
              sponsored={a.data.sponsored}
            />
          ))}
        </div>
      </div>
    )}

    <!-- Disclosure -->
    <div class="p-4 bg-gray-50 rounded-2xl border border-gray-100">
      <p class="text-xs text-gray-400 leading-relaxed">
        <strong class="text-gray-500">Advertising Disclosure:</strong> This page contains affiliate links. Verto may receive a commission when you purchase through these links, at no additional cost to you. We only feature offers we believe are genuinely useful. Individual results vary. Consult a qualified professional before starting any health, financial, or legal program.
      </p>
    </div>
  </div>

  <!-- Sticky CTA bar -->
  {topOffer && (
    <StickyCtaBar
      text={`${topOffer.shortName} — ${topOffer.tagline}`}
      ctaText={topOffer.ctaText}
      ctaUrl={getAffiliateUrl(topOffer, problem.slug)}
    />
  )}

  <!-- Scroll depth + CTA tracking -->
  <ScrollTracker pageName={`problem-${problem.slug}`} />

  <!-- UTM-aware headline swap -->
  <script>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var angle = params.get('utm_angle') || params.get('utm_content');
    if (!angle) return;
    var h1 = document.getElementById('utm-headline');
    if (!h1) return;
    var variants = {
      pain:        h1.dataset.painHeadline,
      social:      h1.dataset.socialHeadline,
      aspiration:  h1.dataset.socialHeadline,
    };
    if (variants[angle]) {
      h1.textContent = variants[angle];
    }
  })();
  </script>
</BaseLayout>

<style>
  details[open] summary { background-color: rgb(249 250 251); }
</style>
