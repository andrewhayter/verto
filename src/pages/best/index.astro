---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { problems } from '../../data/problems';
import { offersByProblem } from '../../data/offers';
---

<BaseLayout
  title={`Verto Problem Guides — ${problems.length} Consumer Problems with Specific Verdicts`}
  description={`One guide per problem — weight loss medications, personal loans, online privacy, menopause treatment, and ${problems.length - 4} more. Each guide has the evidence, the verdict, and a direct path to the right solution.`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "@id": "https://verto.fun/best#webpage",
        "name": `${problems.length} Problem-Solution Guides`,
        "description": `One problem guide per consumer question — evidence, verdict, and a direct path to the right solution.`,
        "url": "https://verto.fun/best",
        "isPartOf": { "@id": "https://verto.fun/#website" },
        "publisher": { "@id": "https://verto.fun/#organization" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://verto.fun" },
          { "@type": "ListItem", "position": 2, "name": "Solution Guides", "item": "https://verto.fun/best" }
        ]
      }
    ]
  })} />

  <div class="bg-slate-900 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3">
        {problems.length} Consumer Problems — One Guide Each, with Pricing, Evidence, and a Verdict
      </h1>
      <p class="text-white/60 text-lg max-w-xl">
        One guide per problem: ranked offers compared on price, eligibility, and clinical or technical evidence. No fluff, no padding.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {problems.map(problem => {
        const problemOffers = (offersByProblem[problem.slug] ?? []).filter(o => o.approved);
        const topOffer = problemOffers[0];
        return (
          <a
            href={`/best/${problem.slug}`}
            class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-gray-200 transition-all overflow-hidden flex flex-col"
          >
            <div class="h-28 relative overflow-hidden">
              <img src={`/images/${problem.category}.jpg`} alt={problem.headline} class="w-full h-full object-cover" onerror="this.src='/images/default.jpg'" />
              <div class="absolute inset-0 bg-black/40"></div>
              <div class="absolute bottom-3 left-4 z-10">
                <p class="text-white/80 text-xs font-semibold uppercase tracking-widest">{problemOffers.length} option{problemOffers.length !== 1 ? 's' : ''} compared</p>
              </div>
            </div>
            <div class="p-5 flex-1 flex flex-col">
              <h2 class="font-display font-bold text-gray-900 text-base leading-snug mb-2 group-hover:text-brand transition-colors line-clamp-2">
                {problem.headline}
              </h2>
              <p class="text-gray-500 text-sm leading-relaxed flex-1 line-clamp-2">
                {problem.subheadline}
              </p>
              {topOffer && (
                <div class="mt-4 pt-4 border-t border-gray-50 flex items-center justify-between">
                  <div>
                    <p class="text-xs text-gray-400">Top pick</p>
                    <p class="text-sm font-semibold text-gray-700">{topOffer.shortName}</p>
                  </div>
                  <span class="text-brand text-sm font-bold group-hover:translate-x-0.5 transition-transform">
                    Explore →
                  </span>
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>

    <!-- Bottom CTA — catches visitors who browsed without clicking a card -->
    <div class="mt-14 rounded-3xl overflow-hidden" style="background: linear-gradient(135deg, #14532d, #166534);">
      <div class="p-8 md:p-10 text-center">
        <p class="eyebrow text-green-300 mb-2">Not sure which guide fits your situation?</p>
        <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-3">
          Start With the Most Common Problem
        </h2>
        <p class="text-green-200 text-sm mb-6 max-w-sm mx-auto">
          Our GLP-1 guide is the most-read — compounded tirzepatide from $179/month, same active molecule as Mounjaro.
        </p>
        <a
          href="/best/cant-lose-weight"
          class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-900 font-bold px-8 py-4 rounded-2xl text-base transition-colors min-h-[56px]"
        >
          See GLP-1 Options — From $179/Month →
        </a>
        <p class="text-green-300/60 text-xs mt-3">Checking eligibility is free · No commitment</p>
      </div>
    </div>
  </div>
</BaseLayout>
