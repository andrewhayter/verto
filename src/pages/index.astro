---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedHero from '../components/FeaturedHero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import OfferCard from '../components/OfferCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';
import { problems } from '../data/problems';
import { offersByProblem, topOffers } from '../data/offers';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const featuredArticle = sortedArticles.find(a => a.data.featured) ?? sortedArticles[0];
const recentArticles = sortedArticles
  .filter(a => a.id !== featuredArticle?.id)
  .slice(0, 6);

function getArticleSlug(article: (typeof allArticles)[0]) {
  const parts = article.id.split('/');
  return parts[parts.length - 1].replace(/\.mdx?$/, '');
}

// Spotlight problems — ones with approved offers
const spotlightProblems = problems
  .filter(p => (offersByProblem[p.slug] ?? []).filter(o => o.approved).length > 0)
  .slice(0, 6);

// Top offers for a sidebar strip
const featuredTopOffers = topOffers.slice(0, 5);
---

<BaseLayout
  title="Verto — Find the Best Solution for Your Problem"
  description="Verto matches you with the best-rated offers for health, finance, legal, and lifestyle needs. Expert guides, real comparisons, genuine solutions."
>
  <!-- Schema for homepage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Verto — Find the Best Solution for Your Problem",
    "description": "Verto matches you with the best-rated offers for health, finance, legal, and lifestyle needs.",
    "url": "https://verto.pages.dev",
    "breadcrumb": { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://verto.pages.dev" }] }
  })} />

  <!-- Ticker bar -->
  <div class="ticker-bar text-white text-xs font-semibold py-2 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center gap-2">
      <span class="uppercase tracking-widest shrink-0 mr-3 opacity-80">Trending:</span>
      <div class="flex gap-8 overflow-x-auto category-nav">
        {spotlightProblems.map(p => (
          <a href={`/solve/${p.slug}`} class="whitespace-nowrap hover:underline opacity-90">
            {p.emoji} {p.headline.split('—')[0].trim().substring(0, 55)}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <!-- Hero: Problem Finder -->
    <div class="mb-14">
      <div class="text-center max-w-3xl mx-auto mb-10">
        <h1 class="font-display text-4xl md:text-5xl font-black text-gray-900 leading-tight mb-4">
          What problem are you<br class="hidden sm:block" /> trying to solve today?
        </h1>
        <p class="text-gray-500 text-lg">
          Verto finds the best-rated solution for your specific situation — verified offers, honest comparisons, real results.
        </p>
      </div>

      <!-- Problem grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        {spotlightProblems.map(problem => {
          const problemOffers = (offersByProblem[problem.slug] ?? []).filter(o => o.approved);
          const topOffer = problemOffers[0];
          return (
            <a
              href={`/solve/${problem.slug}`}
              class="group relative flex flex-col justify-between rounded-2xl overflow-hidden p-6 min-h-[200px] hover:shadow-lg transition-all"
              style={`background: ${problem.gradient}`}
            >
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/30 transition-colors"></div>
              <div class="relative z-10">
                <div class="text-3xl mb-3">{problem.emoji}</div>
                <h2 class="font-display font-bold text-white text-lg leading-snug line-clamp-2">
                  {problem.headline.split('?')[0].substring(0, 70)}{problem.headline.includes('?') ? '?' : ''}
                </h2>
              </div>
              <div class="relative z-10 mt-4">
                {topOffer && (
                  <p class="text-white/70 text-xs mb-2">Top pick: <span class="text-white font-semibold">{topOffer.shortName}</span></p>
                )}
                <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest bg-white/15 hover:bg-white/25 text-white px-3 py-1.5 rounded-full transition-colors">
                  Find My Solution
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>

      <div class="text-center">
        <a href="/solve" class="inline-flex items-center gap-2 text-brand hover:text-brand-dark font-semibold text-sm transition-colors">
          Browse all problem guides
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Today's Top Offers strip -->
    <section class="mb-14">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div class="w-1 h-7 bg-brand rounded-full"></div>
          <h2 class="font-display font-bold text-2xl text-gray-900">Today's Top Offers</h2>
          <span class="text-xs text-gray-400 hidden sm:block">Ranked by EPC · Updated daily</span>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        {featuredTopOffers.map((offer, i) => (
          <OfferCard offer={offer} rank={i + 1} variant="compact" />
        ))}
      </div>
    </section>

    <!-- Editorial articles grid -->
    {recentArticles.length > 0 && (
      <section class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <div class="w-1 h-7 bg-brand rounded-full"></div>
            <h2 class="font-display font-bold text-2xl text-gray-900">Expert Guides & Reviews</h2>
          </div>
          <a href="/categories" class="text-brand hover:text-brand-dark text-sm font-semibold transition-colors">
            View All →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {recentArticles.map(article => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              category={article.data.category}
              slug={getArticleSlug(article)}
              author={article.data.author}
              date={article.data.date}
              readTime={article.data.readTime}
              sponsored={article.data.sponsored}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Newsletter -->
    <div class="mb-14">
      <Newsletter />
    </div>

    <!-- All categories -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-7 bg-brand rounded-full"></div>
        <h2 class="font-display font-bold text-2xl text-gray-900">Browse All Categories</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {categories.map(cat => (
          <a
            href={`/category/${cat.slug}`}
            class="group flex flex-col items-center gap-3 p-5 bg-white rounded-2xl shadow-sm border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all text-center"
          >
            <div
              class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl"
              style={`background: ${cat.gradient}`}
            >
              {cat.emoji}
            </div>
            <div>
              <p class="font-semibold text-sm text-gray-800 group-hover:text-brand transition-colors leading-tight">{cat.name}</p>
              <p class="text-xs text-gray-400 mt-0.5">{cat.offsCount} offers</p>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
