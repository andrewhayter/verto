---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Verto matches you with expert-reviewed offers for health, finance, legal, and lifestyle needs — honest comparisons, real results.',
  image = '/favicon.svg',
} = Astro.props;

const siteTitle = title === 'Verto' ? title : `${title} | Verto`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Verto" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <title>{siteTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Organization + WebSite schema -->
  <!-- IMPORTANT: sameAs array below must be populated with real profile URLs before launch.
       Required: Wikidata entity URL, Wikipedia article URL (if exists), LinkedIn company page, Twitter/X profile, Crunchbase profile.
       Create each profile first, then paste the canonical URL here. Wikidata is highest priority — it feeds Knowledge Graphs used by ChatGPT and Google. -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://verto.pages.dev/#organization",
        "name": "Verto",
        "alternateName": "Verto Editorial",
        "url": "https://verto.pages.dev",
        "logo": {
          "@type": "ImageObject",
          "url": "https://verto.pages.dev/favicon.svg",
          "width": 512,
          "height": 512
        },
        "description": "Independent affiliate advertorial publication. Researches and compares vetted offers for health, finance, legal, and consumer technology to help readers solve specific problems.",
        "foundingDate": "2025",
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "hello@verto.pages.dev",
          "contactType": "editorial"
        },
        "sameAs": [
          "https://verto.pages.dev"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://verto.pages.dev/#website",
        "name": "Verto",
        "url": "https://verto.pages.dev",
        "publisher": { "@id": "https://verto.pages.dev/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://verto.pages.dev/topics?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  })}</script>
</head>
<body class="min-h-screen bg-surface">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
